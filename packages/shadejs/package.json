{
  "name": "shadejs",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.js",
      "require": "./dist/compiler.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/compiler.ts --dts --format esm,cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shadejs/compiler": "workspace:*",
    "@shadejs/core": "workspace:*",
    "@shadejs/runtime": "workspace:*",
    "@shadejs/state": "workspace:*"
  }
}
